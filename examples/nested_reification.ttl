@prefix : <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

:stmt1 a rdf:Statement ;
    rdf:subject :alice ;
    rdf:predicate :knows ;
    rdf:object :bob ;
    :source :dataset1 .

:stmt2 a rdf:Statement ;
    rdf:subject :charlie ;
    rdf:predicate :reported ;
    rdf:object :stmt1 ;
    :source :auditLog .
